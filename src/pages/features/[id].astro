---
import Layout from '../../layouts/Layout.astro';
import { features } from '../../data/features';

export async function getStaticPaths() {
  return features.map((feat) => ({
    params: { id: feat.id },
    props: { feat },
  }));
}

const { feat } = Astro.props;

// Determine previous and next features for easy navigation
const currentIndex = features.findIndex(f => f.id === feat.id);
const prevFeature = currentIndex > 0 ? features[currentIndex - 1] : null;
const nextFeature = currentIndex < features.length - 1 ? features[currentIndex + 1] : null;
---

<Layout title={`${feat.title} | omp everyday benefits`} activeFeatureId={feat.id}>
  <div class="space-y-8 animate-fade-in" transition:animate="slide">
    
    <!-- HEADER CARD -->
    <div class="relative rounded-2xl border border-slate-800 bg-[#0C0F1E] p-8 shadow-xl overflow-hidden">
      <!-- Glow decoration -->
      <div class="absolute -top-12 -right-12 w-48 h-48 rounded-full bg-blue-500/10 blur-3xl pointer-events-none"></div>
      
      <div class="flex items-center space-x-3 mb-4">
        <span class="text-xs font-mono font-bold text-blue-400 bg-blue-500/10 px-2.5 py-1 rounded border border-blue-500/20">
          {feat.category}
        </span>
        <span class="text-xs font-mono text-slate-500">
          Feature #{feat.num}
        </span>
      </div>

      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white mb-3">
        {feat.title}
      </h1>

      <p class="text-lg font-semibold text-emerald-400 leading-relaxed max-w-3xl">
        {feat.benefit}
      </p>
    </div>

    <!-- MAIN GRID -->
    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
      
      <!-- Left side: Explanations and Scenarios -->
      <div class="xl:col-span-7 space-y-8">
        
        <!-- Explanation block -->
        <div class="prose prose-invert max-w-none">
          <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <span class="w-1.5 h-6 bg-blue-500 rounded-full"></span>
            How It Works
          </h2>
          <p class="text-slate-300 leading-relaxed text-base">
            {feat.explanation}
          </p>
          <p class="text-slate-400 leading-relaxed text-sm mt-3">
            {feat.summary}
          </p>
        </div>

        <!-- Scenario block -->
        <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-6 relative overflow-hidden">
          <div class="absolute -right-4 -bottom-4 text-6xl text-amber-500/5 select-none font-bold">💡</div>
          <h3 class="text-base font-bold text-amber-400 mb-2">Real-World Scenario</h3>
          <p class="text-sm text-slate-300 leading-relaxed">
            {feat.scenario}
          </p>
        </div>

        <!-- Keyboard shortcut card (if any) -->
        {feat.shortcut && (
          <div class="flex items-center justify-between rounded-xl border border-slate-800 bg-[#0C0F1E] p-6 shadow-md">
            <div>
              <h3 class="text-sm font-bold text-slate-200">Muscle-Memory Shortcut</h3>
              <p class="text-xs text-slate-400 mt-0.5">Toggle this setting instantly via physical keys</p>
            </div>
            <kbd class="px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-sm font-bold text-white shadow-inner font-mono">
              {feat.shortcut}
            </kbd>
          </div>
        )}
      </div>

      <!-- Right side: Visual Demos (Terminal Mockup & Code) -->
      <div class="xl:col-span-5 space-y-8">
        
        <!-- Terminal Mockup -->
        <div class="rounded-xl border border-slate-800 bg-[#0F111E] shadow-2xl overflow-hidden">
          <!-- Terminal Title bar -->
          <div class="flex items-center justify-between px-4 py-2.5 bg-[#0B0D17] border-b border-slate-900">
            <div class="flex space-x-2">
              <div class="w-2.5 h-2.5 rounded-full bg-rose-500/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-amber-500/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500/80"></div>
            </div>
            <div class="text-[11px] text-slate-500 font-mono font-medium">omp --interactive</div>
            <div class="w-8"></div>
          </div>
          <!-- Terminal Body -->
          <div class="p-5 font-mono text-xs leading-relaxed overflow-x-auto text-slate-350 bg-[#0A0C16]">
            {feat.terminalLines.map((line) => {
              if (line.type === 'input') {
                return (
                  <div class="text-slate-300 mb-2">
                    <span class="text-indigo-400 font-bold">&gt;</span> {line.text}
                  </div>
                );
              } else if (line.type === 'output') {
                return (
                  <div class="text-emerald-400/90 mb-1">
                    {line.text}
                  </div>
                );
              } else if (line.type === 'ticker') {
                return (
                  <div class="text-slate-400 bg-slate-950/60 p-2 rounded border border-slate-900/80 text-[11px] mt-2 mb-2 font-semibold">
                    📊 {line.text}
                  </div>
                );
              } else {
                return (
                  <div class="text-slate-500 mb-2 italic">
                    {line.text}
                  </div>
                );
              }
            })}
          </div>
        </div>

        <!-- Code Config Example (if any) -->
        {feat.codeExample && (
          <div class="rounded-xl border border-slate-800 bg-[#0B0D17] overflow-hidden">
            <div class="flex justify-between items-center px-4 py-2.5 bg-[#070912] border-b border-slate-900">
              <span class="text-xs text-slate-400 font-mono font-semibold">{feat.codeExample.title}</span>
              <span class="text-[10px] text-slate-500 font-mono uppercase">{feat.codeExample.language}</span>
            </div>
            <pre class="p-4 text-xs font-mono text-slate-300 overflow-x-auto bg-[#070912]"><code>{feat.codeExample.code}</code></pre>
          </div>
        )}
      </div>

    </div>

    <!-- PREV / NEXT NAVIGATION -->
    <div class="flex items-center justify-between pt-6 border-t border-slate-800/80 mt-8">
      {prevFeature ? (
        <a
          href={`${import.meta.env.BASE_URL}features/${prevFeature.id}`}
          class="flex items-center space-x-2 text-sm text-slate-400 hover:text-white transition-colors"
        >
          <span>←</span>
          <span>{prevFeature.title}</span>
        </a>
      ) : (
        <div class="w-10"></div>
      )}

      {nextFeature ? (
        <a
          href={`${import.meta.env.BASE_URL}features/${nextFeature.id}`}
          class="flex items-center space-x-2 text-sm text-slate-400 hover:text-white transition-colors"
        >
          <span>{nextFeature.title}</span>
          <span>→</span>
        </a>
      ) : (
        <div class="w-10"></div>
      )}
    </div>

  </div>
</Layout>
