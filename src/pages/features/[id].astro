---
import Layout from '../../layouts/Layout.astro';
import { features } from '../../data/features';

export async function getStaticPaths() {
  return features.map((feat) => ({
    params: { id: feat.id },
    props: { feat },
  }));
}

const { feat } = Astro.props;

// Determine previous and next features for easy navigation
const currentIndex = features.findIndex(f => f.id === feat.id);
const prevFeature = currentIndex > 0 ? features[currentIndex - 1] : null;
const nextFeature = currentIndex < features.length - 1 ? features[currentIndex + 1] : null;

// Helper function to format terminal line text
function formatTerminalLine(text: string, type: string) {
  if (type === 'input') return text;
  
  const isSelected = text.trim().startsWith('❯');
  
  let html = text
    .replace(/● logged in/g, '<span class="text-emerald-500 font-semibold">● logged in</span>')
    .replace(/\(login\)/g, '<span class="text-slate-500">(login)</span>')
    .replace(/\(env\)/g, '<span class="text-slate-500">(env)</span>')
    .replace(/✔ (.*)/g, '<span class="text-emerald-400">✔ $1</span>');
    
  if (isSelected) {
    return `<span class="text-purple-400 font-bold">${html}</span>`;
  }
  
  if (type === 'info') {
    return `<span class="text-slate-500">${html}</span>`;
  }
  
  return `<span class="text-slate-300">${html}</span>`;
}
