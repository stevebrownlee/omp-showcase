---
import Layout from '../layouts/Layout.astro';
import { features, categories } from '../data/features';
---

<Layout title="omp.sh | Everyday Benefits & Supercharged Setup">
  
  <!-- HERO SECTION -->
  <section class="relative pt-8 pb-12 overflow-hidden border-b border-slate-900 bg-[#080B15]/40 rounded-2xl px-6 sm:px-8 mb-12">
    <!-- Glow decoration -->
    <div class="absolute top-0 right-0 w-[300px] h-[300px] rounded-full bg-blue-500/5 blur-[80px] pointer-events-none"></div>
    
    <div class="relative z-10 max-w-4xl">
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-xs font-semibold text-blue-400 mb-6">
        <span>Rethinking the developer-agent experience</span>
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
      </div>
      
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white mb-6 leading-tight">
        The CLI Coding Assistant that <br/>
        <span class="bg-gradient-to-r from-blue-400 via-indigo-400 to-emerald-400 bg-clip-text text-transparent">
          Thinks Like a Developer
        </span>
      </h1>
      
      <p class="text-base sm:text-lg text-slate-400 mb-8 max-w-2xl leading-relaxed">
        Forget synthetic benchmarks and raw LSP charts. Discover the everyday benefits of <strong class="text-slate-200">omp</strong> — the first terminal assistant built for flow state, budget transparency, and true multi-model collaboration.
      </p>
      
      <div class="flex flex-wrap gap-4">
        <a href="#directory" class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-semibold shadow-lg shadow-blue-500/20 transition-all duration-150 text-sm">
          Browse 12 Killer Features
        </a>
        <a href="#workflow" class="px-6 py-3 rounded-xl bg-slate-900 hover:bg-slate-800 text-slate-300 font-semibold border border-slate-800 transition-all duration-150 text-sm">
          Setup Your Second Brain
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURES DIRECTORY GRID -->
  <section id="directory" class="py-12 border-b border-slate-900">
    <div class="mb-8">
      <h2 class="text-2xl font-bold tracking-tight text-white mb-2">
        Feature Directory
      </h2>
      <p class="text-sm text-slate-400">
        Click any feature to open its interactive, detailed view in the sidebar.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      {features.map((feat) => (
        <a
          href={`${import.meta.env.BASE_URL}features/${feat.id}`}
          class="group block p-5 rounded-xl border border-slate-800/80 bg-[#0C0F1E] hover:bg-[#111529] hover:border-slate-700 transition-all duration-200 shadow-md"
        >
          <div class="flex justify-between items-start mb-3">
            <span class="text-[10px] font-mono font-bold text-blue-500 bg-blue-500/10 px-2 py-0.5 rounded">
              {feat.num}
            </span>
            <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">
              {feat.category.split(' ')[0]}
            </span>
          </div>
          <h3 class="text-sm font-bold text-white group-hover:text-blue-400 transition-colors mb-1">
            {feat.title}
          </h3>
          <p class="text-xs text-slate-400 line-clamp-2">
            {feat.benefit}
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- SUPERCHARGED WORKFLOW & INTEGRATION -->
  <section id="workflow" class="py-12 border-b border-slate-900 relative">
    <div class="lg:grid lg:grid-cols-12 lg:gap-8 items-start">
      
      <div class="lg:col-span-5 mb-8 lg:mb-0">
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-semibold text-emerald-400 mb-6">
          <span>The Setup of Champions</span>
        </div>
        
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-6">
          Your "Second Brain" Setup
        </h2>
        
        <p class="text-slate-400 mb-6 text-sm leading-relaxed">
          While <strong class="text-slate-350">omp</strong> is powerful on its own, its true potential is unlocked when you wire it with two essential ecosystem tools:
        </p>

        <div class="space-y-6">
          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 rounded-lg bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 flex items-center justify-center font-bold font-mono text-xs flex-shrink-0 mt-0.5">
              W
            </div>
            <div>
              <h4 class="text-sm font-bold text-white">Worktree Bash Helper</h4>
              <p class="text-xs text-slate-450 mt-0.5">
                Isolate tasks into clean, ephemeral git worktrees. This allows your agent to work independently without cluttering your active working directory.
              </p>
            </div>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 flex items-center justify-center font-bold font-mono text-xs flex-shrink-0 mt-0.5">
              E
            </div>
            <div>
              <h4 class="text-sm font-bold text-white">Engrams CLI</h4>
              <p class="text-xs text-slate-450 mt-0.5">
                A Rust-built, zero-overhead persistent project memory. It stores architectural decisions (ADRs), system patterns, and task progress in a local, Git-syncable SQLite database.
              </p>
            </div>
          </div>
        </div>

        <p class="text-xs text-slate-400 mt-6 leading-relaxed italic border-l-2 border-blue-500 pl-4">
          "When combined with my worktree bash function and the engrams knowledge management cli tool, it's about as close as you can get to having a second brain that learns and grows with you in a project over time."
        </p>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-xl border border-slate-800 bg-[#0B0D17] p-5 shadow-xl">
          <div class="flex items-center justify-between mb-4 border-b border-slate-800 pb-3">
            <h3 class="text-xs font-bold text-slate-350 font-mono flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
              Ecosystem Integration Workflow
            </h3>
            <span class="text-[10px] text-slate-500 font-mono">bash & markdown</span>
          </div>
          
          <div class="space-y-4">
            <!-- Worktree bash snippet -->
            <div>
              <div class="flex justify-between items-center mb-1">
                <span class="text-xs text-indigo-400 font-semibold">1. Git Worktree Helper</span>
                <span class="text-[10px] text-slate-500">.bashrc / .zshrc</span>
              </div>
              <pre class="p-3 bg-[#070912] rounded-lg border border-slate-900 text-xs font-mono text-slate-300 overflow-x-auto">
# Create feature branch, mount worktree, & open omp
wt-omp() &#123;
  local name=$1
  git worktree add ../wt-$name -b feat/$name
  cd ../wt-$name
  omp
&#125;</pre>
              <div class="mt-3 rounded-lg overflow-hidden border border-slate-800 bg-[#070912] p-1">
                <img src={`${import.meta.env.BASE_URL}worktree-helper.png`} alt="Git Worktree Helper in action" class="w-full h-auto rounded opacity-85 hover:opacity-100 transition-opacity duration-200" />
              </div>
            </div>

            <!-- Engrams CLI snapshot -->
            <div>
              <div class="flex justify-between items-center mb-1">
                <span class="text-xs text-emerald-400 font-semibold">2. Engrams Memory CLI</span>
                <span class="text-[10px] text-slate-500">Rust & SQLite (FTS5)</span>
              </div>
              <pre class="p-3 bg-[#070912] rounded-lg border border-slate-900 text-xs font-mono text-slate-300 overflow-x-auto">
# Log architectural decisions that persist across workspaces
$ engrams decision log --summary "Use Postgres" --rationale "ACID guarantees"

# Generate a token-budget optimized context brief for the omp agent
$ engrams prime &gt; .omp/context-brief.md</pre>
            </div>

            <!-- Workflow diagram -->
            <div class="pt-2">
              <span class="text-xs text-slate-500 font-semibold block mb-2">Workspace Brain Loop:</span>
              <div class="grid grid-cols-3 gap-2 text-center text-[10px] font-mono">
                <div class="p-2 bg-indigo-500/10 border border-indigo-500/20 rounded">
                  <div class="font-bold text-indigo-300">1. Git Worktree</div>
                  <div class="text-[9px] text-slate-500 mt-1">Clean Isolation</div>
                </div>
                <div class="p-2 bg-blue-500/10 border border-blue-500/20 rounded">
                  <div class="font-bold text-blue-300">2. omp Agent</div>
                  <div class="text-[9px] text-slate-500 mt-1">Task Autopilot</div>
                </div>
                <div class="p-2 bg-emerald-500/10 border border-emerald-500/20 rounded">
                  <div class="font-bold text-emerald-300">3. Engrams</div>
                  <div class="text-[9px] text-slate-500 mt-1">Persistent Memory</div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- COMPARISON TABLE SECTION -->
  <section id="comparison" class="py-12 border-b border-slate-900 bg-[#080B15]/20 rounded-2xl px-6 mb-12">
    <div class="mb-8">
      <h2 class="text-2xl font-bold tracking-tight text-white mb-2">
        How omp Beats the Competition
      </h2>
      <p class="text-sm text-slate-400">
        Why terminal-focused developers are switching from heavy IDE integrations to clean, lightweight CLI orchestrators.
      </p>
    </div>

    <div class="overflow-x-auto rounded-xl border border-slate-800 bg-[#0C0F1E]">
      <table class="w-full text-left border-collapse text-xs sm:text-sm">
        <thead>
          <tr class="border-b border-slate-800 bg-[#0B0D17]">
            <th class="p-3 sm:p-4 font-bold text-white">Feature Advantage</th>
            <th class="p-3 sm:p-4 font-bold text-indigo-400">omp CLI</th>
            <th class="p-3 sm:p-4 font-bold text-slate-400">Traditional Copilots</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/60">
          <tr>
            <td class="p-3 sm:p-4 font-medium text-slate-200">Subscription Freedom</td>
            <td class="p-3 sm:p-4 text-emerald-400 font-medium">Yes — Login to all your subs</td>
            <td class="p-3 sm:p-4 text-slate-550">No — Pay for a separate seat</td>
          </tr>
          <tr>
            <td class="p-3 sm:p-4 font-medium text-slate-200">Dynamic Reasoning Swaps</td>
            <td class="p-3 sm:p-4 text-emerald-400 font-medium">Yes — ctrl+p / shift+tab on the fly</td>
            <td class="p-3 sm:p-4 text-slate-550">No — Single model lock-in per workspace</td>
          </tr>
          <tr>
            <td class="p-3 sm:p-4 font-medium text-slate-200">Double-Team Brains</td>
            <td class="p-3 sm:p-4 text-emerald-400 font-medium">Yes — Secondary Advisor modes</td>
            <td class="p-3 sm:p-4 text-slate-550">No — One agent only</td>
          </tr>
          <tr>
            <td class="p-3 sm:p-4 font-medium text-slate-200">Cost Transparency</td>
            <td class="p-3 sm:p-4 text-emerald-400 font-medium">Yes — Real-time micro-cent tickers</td>
            <td class="p-3 sm:p-4 text-slate-550">No — hidden credit systems</td>
          </tr>
          <tr>
            <td class="p-3 sm:p-4 font-medium text-slate-200">Self-Correcting Loops</td>
            <td class="p-3 sm:p-4 text-emerald-400 font-medium">Yes — /goal command auto-testing</td>
            <td class="p-3 sm:p-4 text-slate-550">No — Manual copy-paste errors</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA / INSTALLATION -->
  <section id="get-started" class="py-12 text-center bg-gradient-to-b from-[#0A0D1A] to-[#060810] rounded-2xl border border-slate-900">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-4">
      Ready to Build Your Second Brain?
    </h2>
    <p class="text-slate-400 mb-6 text-sm max-w-xl mx-auto">
      Install the lightweight CLI companion and connect your existing subscriptions to unlock a whole new coding velocity.
    </p>
    
    <div class="bg-[#0B0D17] border border-slate-800 rounded-xl p-4 max-w-md mx-auto mb-8 flex items-center justify-between font-mono text-sm">
      <span class="text-slate-300 select-all">curl -fsSL https://omp.sh/install | sh</span>
      <button id="copy-btn" class="text-blue-500 hover:text-blue-400 px-3 py-1 bg-blue-500/10 rounded border border-blue-500/20 text-xs font-semibold font-sans transition-colors">
        Copy
      </button>
    </div>

    <div class="text-xs text-slate-500">
      Requires Node 18+, Bun, or Python environment. Supports macOS, Linux, and Windows WSL.
    </div>
  </section>

  <script>
    const copyBtn = document.getElementById('copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText('curl -fsSL https://omp.sh/install | sh');
        copyBtn.innerText = 'Copied!';
        setTimeout(() => {
          copyBtn.innerText = 'Copy';
        }, 2000);
      });
    }
  </script>

</Layout>
